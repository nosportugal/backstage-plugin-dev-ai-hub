{
  "extends": "@backstage/cli/config/tsconfig.json",
  "include": [
    "plugins/*/src",
    "plugins/*/dev"
  ],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "outDir": "dist-types",
    "rootDir": ".",
    "useUnknownInCatchVariables": false,
    "jsx": "react-jsx",
    "types": ["node", "jest"],
    "noUnusedLocals": false
  }
}
