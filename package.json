{
  "name": "backstage-plugin-dev-ai-hub",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "plugins/*"
  ],
  "scripts": {
    "start": "yarn start:frontend & yarn start:backend",
    "start:frontend": "yarn workspace @nospt/plugin-dev-ai-hub start",
    "start:backend": "yarn workspace @nospt/plugin-dev-ai-hub-backend start",
    "build:all": "yarn workspaces foreach --all --topological-dev run build",
    "test": "yarn workspaces foreach --all -p run test --passWithNoTests",
    "lint:all": "yarn workspaces foreach --all -p run lint",
    "tsc": "tsc"
  },
  "devDependencies": {
    "@backstage/cli": "*",
    "jest": "^29.0.0",
    "typescript": "^5.3.0"
  },
  "resolutions": {
    "axios": ">=1.15.2",
    "fast-uri": ">=3.1.2",
    "fast-xml-builder": ">=1.1.7",
    "fast-xml-parser": ">=5.5.6",
    "flatted": ">=3.4.2",
    "handlebars": ">=4.7.9",
    "koa": ">=3.1.2",
    "lodash": ">=4.18.0",
    "node-forge": ">=1.4.0",
    "express/path-to-regexp": "0.1.13",
    "protobufjs": ">=7.5.5",
    "undici": ">=6.24.0",
    "vm2": ">=3.11.1",
    "@backstage/backend-defaults": ">=0.12.2"
  },
  "packageManager": "yarn@4.5.3"
}
