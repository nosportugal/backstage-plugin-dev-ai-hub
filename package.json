{
  "name": "backstage-plugin-dev-ai-hub",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "plugins/*"
  ],
  "scripts": {
    "start:frontend": "yarn workspace @internal/plugin-dev-ai-hub start",
    "start:backend": "yarn workspace @internal/plugin-dev-ai-hub-backend start",
    "build:all": "yarn workspaces foreach --all --topological-dev run build",
    "test": "yarn workspaces foreach --all -p run test --passWithNoTests",
    "lint:all": "yarn workspaces foreach --all -p run lint",
    "tsc": "tsc"
  },
  "devDependencies": {
    "@backstage/cli": "*",
    "jest": "^29.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "yarn@4.5.3"
}
