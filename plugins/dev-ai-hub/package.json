{
  "name": "@nospt/plugin-dev-ai-hub",
  "version": "0.2.1",
  "description": "Frontend plugin for Dev AI Hub",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/JulianPedro/backstage-dev-ai-hub"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/nosportugal/backstage-plugin-dev-ai-hub"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "package.json": [
        "package.json"
      ]
    }
  },
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "dev-ai-hub",
    "pluginPackages": [
      "@nospt/plugin-dev-ai-hub",
      "@nospt/plugin-dev-ai-hub-backend",
      "@nospt/plugin-dev-ai-hub-common",
      "@nospt/plugin-dev-ai-hub-node"
    ]
  },
  "sideEffects": false,
  "scripts": {
    "start": "backstage-cli package start --config ../../app-config.dev.yaml",
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "lint": "backstage-cli package lint",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "test": "backstage-cli package test --passWithNoTests --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@backstage/core-components": "^0.18.9",
    "@backstage/core-plugin-api": "^1.12.5",
    "@backstage/frontend-plugin-api": "^0.16.2",
    "@backstage/ui": "^0.14.3",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@nospt/plugin-dev-ai-hub-common": "workspace:^",
    "@remixicon/react": "^4.6.0",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^13.0.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.1",
    "@backstage/dev-utils": "^1.1.22",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.0.0",
    "@types/react-syntax-highlighter": "^15.0.0",
    "jest": "^30.2.0",
    "jsdom": "^27.1.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.30.2"
  },
  "peerDependencies": {
    "@backstage/core-components": ">=1.40.0",
    "@backstage/core-plugin-api": ">=1.40.0",
    "@backstage/frontend-plugin-api": ">=1.40.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0"
  }
}
