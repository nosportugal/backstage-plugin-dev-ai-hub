{
  "name": "@julianpedro/plugin-dev-ai-hub-common",
  "version": "0.2.4",
  "description": "Common types and schemas for Dev AI Hub",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/JulianPedro/backstage-dev-ai-hub"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "package.json": [
        "package.json"
      ]
    }
  },
  "backstage": {
    "role": "common-library",
    "pluginId": "dev-ai-hub",
    "pluginPackages": [
      "@julianpedro/plugin-dev-ai-hub",
      "@julianpedro/plugin-dev-ai-hub-backend",
      "@julianpedro/plugin-dev-ai-hub-common",
      "@julianpedro/plugin-dev-ai-hub-node"
    ]
  },
  "sideEffects": false,
  "scripts": {
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "lint": "backstage-cli package lint",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "test": "backstage-cli package test --passWithNoTests --watchAll=false",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.1",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0"
  }
}
